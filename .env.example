# Database (PostgreSQL)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=newsletter
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# MinIO (object storage for article content)
S3_ENDPOINT=localhost:9000
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio123

# SMTP (for real emails — leave blank to use mock provider)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TLS=true

# LLM — NVIDIA is the default provider
NVIDIA_API_KEY=
NVIDIA_MODEL=meta/llama-3.3-70b-instruct

# Tavily search (optional — adds external search beyond RSS)
ENABLE_TAVILY=false
TAVILY_API_KEY=

# Playwright / web scraping
PLAYWRIGHT_ENABLED=true
USER_AGENT=AgenticNewsletterBot/1.0 (+contact:you@example.com)
SCRAPE_TIMEOUT_SECS=30
SCRAPE_MIN_WORDS=120

# Debug
DEBUG=false
